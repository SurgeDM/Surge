{
  "name": "surge-extension",
  "description": "Surge Download Manager browser extension",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "pretest": "wxt prepare",
    "test": "vitest run"
  },
  "dependencies": {
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.1.10",
    "wxt": "^0.20.26"
  }
}
