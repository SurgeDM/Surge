#!/bin/bash

echo "Running pre-push checks..."

# Check formatting
echo "Checking formatting (go fmt)..."
fmt_files=$(gofmt -l .)
if [ -n "$fmt_files" ]; then
    echo "The following files are not properly formatted:"
    echo "$fmt_files"
    echo "Please run 'go fmt ./...' and commit the changes."
    exit 1
fi

# Check lint
echo "Running linter (golangci-lint)..."
if ! golangci-lint run ./...; then
    echo "Linter failed. Please fix the issues above."
    exit 1
fi

# Run tests
echo "Running tests (go test)..."
if ! go test ./...; then
    echo "Tests failed. Please fix the failures above."
    exit 1
fi

echo "All checks passed! Proceeding with push."
exit 0
